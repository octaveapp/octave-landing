---
import Section from '../Section.astro';
import Paragraph from '../Paragraph.astro';
---

<Section>
  <h3 style="margin-top: 12rem;">Utilisez Octave en avant première</h3>
  <Paragraph>
    Vous cherchez à améliorer votre alimentation ? A simplifier votre
    quotidien ? Inscrivez-vous pour faire partie des premiers utilisateurs
    d'Octave
  </Paragraph>
  <div class="grid-12 has-gutter">
    <div class="col-3-small-2"></div>
    <div class="col-6-small-8">
      <form
        class="mc-form"
        action="https://octaveapp.us19.list-manage.com/subscribe/post?u=805240da53e89b7d83a9b36e5&amp;id=0ceedd5d8e"
        method="post"
        id="mc-embedded-subscribe-form"
        name="mc-embedded-subscribe-form"
        target="_blank"
      >
        <div id="mc_embed_signup_scroll">
          <div class="mc-field-group">
            <input
              type="text"
              name="FNAME"
              id="mce-FNAME"
              placeholder="Votre prénom"
              required
            />
          </div>
          <div class="mc-field-group">
            <input
              type="text"
              name="LNAME"
              id="mce-LNAME"
              placeholder="Votre nom"
              required
            />
          </div>
        </div>
        <div class="mc-field-group">
          <input
            type="email"
            name="EMAIL"
            class="required email"
            id="mce-EMAIL"
            placeholder="Votre adresse email"
            required
          />
        </div>
        <div style="position: absolute; left: -5000px;" aria-hidden="true">
          <input
            type="text"
            name="b_805240da53e89b7d83a9b36e5_0ceedd5d8e"
            tabindex="-1"
            value=""
          />
        </div>
        <input
          type="submit"
          value="Je m'inscris"
          name="subscribe"
          id="mc-embedded-subscribe"
          class="submit-button"
        />
      </form>
    </div>
    <div class="col-3-small-2"></div>
  </div>
</Section>

<style>
  .mc-form {
    text-align: center;
  }
  .mc-form .mc-field-group input {
    padding: 1.5rem;
    display: inline-block;
    width: 100%;
    border-radius: 1rem;
    border: 1px solid #bce4b9;
    box-shadow: none;
    margin-bottom: 2rem;
  }
  .mc-form .mc-field-group input::placeholder {
    color: #373f51;
  }
  .mc-form .submit-button {
    background-color: #6cc566;
    border-radius: 1.3rem;
    color: #fff;
    padding: 0.8rem 2.5rem;
    border: none;
    box-shadow: none;
  }
</style>
